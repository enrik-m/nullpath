{
  "name": "nullpath",
  "private": true,
  "version": "0.23.5-beta.1",
  "type": "module",
  "scripts": {
    "predev": "node scripts/copy-sql-wasm.mjs",
    "dev": "vite",
    "prebuild": "node scripts/copy-sql-wasm.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "seed:build": "node scripts/build-seed.mjs",
    "seed:build:cloud": "node scripts/build-seed-cloud.mjs",
    "build:branding": "node scripts/build-branding.mjs",
    "capture:screenshots": "node scripts/capture-screenshots.mjs",
    "capture:demo": "node scripts/capture-demo.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/press-start-2p": "^5.2.7",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/silkscreen": "^5.2.8",
    "@supabase/supabase-js": "^2.105.3",
    "@tailwindcss/vite": "^4.2.4",
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "howler": "^2.2.4",
    "html-to-image": "^1.11.13",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^1.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-window": "^2.2.7",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.2.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/howler": "^2.2.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/react-window": "^1.8.8",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.0.4",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
